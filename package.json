{
  "name": "qxcode",
  "version": "0.1.0",
  "description": "Isomorphic QR code library with a zero-dependency encoding core and an SVG-first rendering pipeline.",
  "keywords": [
    "qr",
    "qrcode",
    "qr-code",
    "svg",
    "png",
    "webp"
  ],
  "homepage": "https://github.com/s1dny/qxcode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s1dny/qxcode.git"
  },
  "bugs": {
    "url": "https://github.com/s1dny/qxcode/issues"
  },
  "type": "module",
  "module": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts",
      "default": "./index.ts"
    }
  },
  "files": [
    "index.ts",
    "src",
    "img",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "pack:check": "npm pack --dry-run",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "sharp": "*"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  }
}
