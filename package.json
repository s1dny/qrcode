{
  "name": "@sidny/qrcode",
  "version": "0.1.3",
  "description": "Isomorphic QR code library with a zero-dependency encoding core and an SVG-first rendering pipeline.",
  "keywords": [
    "qr",
    "qrcode",
    "qr-code",
    "svg",
    "png",
    "webp"
  ],
  "homepage": "https://github.com/s1dny/qrcode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s1dny/qrcode.git"
  },
  "bugs": {
    "url": "https://github.com/s1dny/qrcode/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "img",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "pack:check": "npm run build && npm pack --dry-run",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "sharp": "*"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  }
}
